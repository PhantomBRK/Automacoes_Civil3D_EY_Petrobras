<Window x:Class="AutomacoesCivil3D.QtoSuperficiesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Quantitativo por Superficies"
        Width="1480"
        Height="860"
        MinWidth="1280"
        MinHeight="760"
        WindowStartupLocation="CenterScreen"
        Background="#F3F6FA"
        FontFamily="Bahnschrift">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />

        <SolidColorBrush x:Key="HeroBrush" Color="#10324B" />
        <SolidColorBrush x:Key="AccentBrush" Color="#157A87" />
        <SolidColorBrush x:Key="SurfaceBrush" Color="#FCFDFE" />
        <SolidColorBrush x:Key="BorderBrushSoft" Color="#D6DFE8" />
        <SolidColorBrush x:Key="TextBrush" Color="#173042" />
        <SolidColorBrush x:Key="MutedBrush" Color="#607080" />

        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
            <Setter Property="CornerRadius" Value="22" />
            <Setter Property="Padding" Value="22" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style x:Key="InputStyle" TargetType="TextBox">
            <Setter Property="Height" Value="40" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="{StaticResource AccentBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="18,12" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="Background" Value="#E7EDF3" />
        </Style>
    </Window.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="330" />
            <ColumnDefinition Width="20" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Row="0"
                Grid.Column="0"
                Background="{StaticResource HeroBrush}"
                CornerRadius="28"
                Padding="26">
            <StackPanel>
                <Border Width="78"
                        Height="78"
                        CornerRadius="20"
                        Background="#1A90A0"
                        HorizontalAlignment="Left">
                    <Viewbox Margin="18">
                        <TextBlock Text="QTO"
                                   Foreground="White"
                                   FontWeight="Bold" />
                    </Viewbox>
                </Border>

                <TextBlock Margin="0,22,0,8"
                           FontSize="28"
                           FontWeight="SemiBold"
                           Foreground="White"
                           Text="Superficies para QTO" />

                <TextBlock TextWrapping="Wrap"
                           Foreground="#C9DAE7"
                           FontSize="14"
                           LineHeight="22"
                           Text="Vincule superficies TIN e TinVolumeSurface aos materiais de pavimentacao e terraplenagem para gerar o mesmo CSV da rotina atual." />

                <Border Margin="0,24,0,0"
                        Style="{StaticResource CardStyle}"
                        Background="#F6FAFD"
                        BorderThickness="0">
                    <StackPanel>
                        <TextBlock Text="Resumo"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextBrush}" />
                        <UniformGrid Margin="0,16,0,0"
                                     Columns="2"
                                     Rows="3">
                            <StackPanel Margin="0,0,10,10">
                                <TextBlock Text="Superficies" Foreground="{StaticResource MutedBrush}" />
                                <TextBlock Text="{Binding SurfaceCount}" FontSize="28" FontWeight="SemiBold" Foreground="{StaticResource HeroBrush}" />
                            </StackPanel>
                            <StackPanel Margin="10,0,0,10">
                                <TextBlock Text="Auto" Foreground="{StaticResource MutedBrush}" />
                                <TextBlock Text="{Binding AutoMappedCount}" FontSize="28" FontWeight="SemiBold" Foreground="{StaticResource HeroBrush}" />
                            </StackPanel>
                            <StackPanel Margin="0,0,10,10">
                                <TextBlock Text="TIN" Foreground="{StaticResource MutedBrush}" />
                                <TextBlock Text="{Binding TinSurfaceCount}" FontSize="22" FontWeight="SemiBold" Foreground="{StaticResource AccentBrush}" />
                            </StackPanel>
                            <StackPanel Margin="10,0,0,10">
                                <TextBlock Text="Volume" Foreground="{StaticResource MutedBrush}" />
                                <TextBlock Text="{Binding VolumeSurfaceCount}" FontSize="22" FontWeight="SemiBold" Foreground="{StaticResource AccentBrush}" />
                            </StackPanel>
                            <StackPanel Margin="0,0,10,0">
                                <TextBlock Text="Selecionadas" Foreground="{StaticResource MutedBrush}" />
                                <TextBlock Text="{Binding SelectedEntriesCount}" FontSize="22" FontWeight="SemiBold" Foreground="{StaticResource AccentBrush}" />
                            </StackPanel>
                            <StackPanel Margin="10,0,0,0">
                                <TextBlock Text="Prontas" Foreground="{StaticResource MutedBrush}" />
                                <TextBlock Text="{Binding ReadyEntriesCount}" FontSize="22" FontWeight="SemiBold" Foreground="{StaticResource AccentBrush}" />
                            </StackPanel>
                        </UniformGrid>
                    </StackPanel>
                </Border>

                <Border Margin="0,18,0,0"
                        Style="{StaticResource CardStyle}"
                        Background="#0F415E"
                        BorderThickness="0">
                    <StackPanel>
                        <TextBlock Text="Padrao sugerido"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="White" />
                        <TextBlock Margin="0,8,0,8"
                                   TextWrapping="Wrap"
                                   Foreground="#D0E2EE"
                                   FontSize="13"
                                   Text="{Binding SuggestedPattern}" />
                        <TextBlock TextWrapping="Wrap"
                                   Foreground="#D0E2EE"
                                   FontSize="12"
                                   Text="{Binding SuggestedExample}" />
                    </StackPanel>
                </Border>

                <Border Margin="0,18,0,0"
                        Style="{StaticResource CardStyle}"
                        Background="#FFF6EF"
                        BorderBrush="#F2D8C8">
                    <TextBlock TextWrapping="Wrap"
                               Foreground="#7B583F"
                               FontSize="13"
                               LineHeight="20"
                               Text="m3 usa VOL ou TOP/BOT. m2 usa AREA ou TOP. Para TRP, a grade agora permite definir Corte, Aterro ou Liquido por material." />
                </Border>
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="0"
                      Grid.Column="2"
                      VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <Border Style="{StaticResource CardStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <CheckBox Content="Gerar CSV de pavimentacao"
                                      FontSize="14"
                                      Foreground="{StaticResource TextBrush}"
                                      IsChecked="{Binding GeneratePavCsv}" />
                            <Grid Margin="0,10,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBox Style="{StaticResource InputStyle}"
                                         Text="{Binding PavCsvPath, UpdateSourceTrigger=PropertyChanged}" />
                                <Button Grid.Column="2"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        Content="Salvar"
                                        Click="BrowsePav_Click" />
                            </Grid>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <CheckBox Content="Gerar CSV de terraplenagem"
                                      FontSize="14"
                                      Foreground="{StaticResource TextBrush}"
                                      IsChecked="{Binding GenerateTrpCsv}" />
                            <Grid Margin="0,10,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBox Style="{StaticResource InputStyle}"
                                         Text="{Binding TrpCsvPath, UpdateSourceTrigger=PropertyChanged}" />
                                <Button Grid.Column="2"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        Content="Salvar"
                                        Click="BrowseTrp_Click" />
                            </Grid>
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Margin="0,18,0,0"
                        Style="{StaticResource CardStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="16" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="10" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="10" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="10" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBox Grid.Column="0"
                                     Style="{StaticResource InputStyle}"
                                     Text="{Binding EntryFilterText, UpdateSourceTrigger=PropertyChanged}" />
                            <Button Grid.Column="2"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Content="Selecionar todas"
                                    Click="SelectAllVisible_Click" />
                            <Button Grid.Column="4"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Content="Limpar marcacao"
                                    Click="ClearSelection_Click" />
                            <Button Grid.Column="6"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Content="Adicionar linha"
                                    Click="AddEntry_Click" />
                            <Button Grid.Column="8"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Content="Remover linhas"
                                    Click="RemoveEntries_Click" />
                        </Grid>

                        <Border Grid.Row="2"
                                CornerRadius="18"
                                BorderBrush="{StaticResource BorderBrushSoft}"
                                BorderThickness="1"
                                Background="White">
                            <DataGrid x:Name="MappingsGrid"
                                      ItemsSource="{Binding EntriesView}"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False"
                                      CanUserDeleteRows="False"
                                      HeadersVisibility="Column"
                                      RowHeight="42"
                                      GridLinesVisibility="Horizontal"
                                      ScrollViewer.HorizontalScrollBarVisibility="Auto" SelectionChanged="MappingsGrid_SelectionChanged">
                                <DataGrid.Columns>
                                    <DataGridCheckBoxColumn Header="Usar" Binding="{Binding IsSelected, Mode=TwoWay}" Width="60" />
                                    <DataGridTextColumn Header="Trecho" Binding="{Binding Segment, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="140" />

                                    <DataGridTemplateColumn Header="Disciplina" Width="140">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <ComboBox ItemsSource="{Binding DataContext.DisciplineOptions, RelativeSource={RelativeSource AncestorType=Window}}"
                                                          DisplayMemberPath="Label"
                                                          SelectedValuePath="Key"
                                                          SelectedValue="{Binding DisciplineKey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>

                                    <DataGridTemplateColumn Header="Material" Width="290">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <ComboBox ItemsSource="{Binding AvailableMaterialOptions}"
                                                          DisplayMemberPath="DisplayLabel"
                                                          SelectedValuePath="Name"
                                                          SelectedValue="{Binding MaterialName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>

                                    <DataGridTextColumn Header="UN" Binding="{Binding UnitLabel}" Width="70" IsReadOnly="True" />

                                    <DataGridTemplateColumn Header="Regra" Width="150">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <ComboBox ItemsSource="{Binding AvailableMeasurementRules}"
                                                          DisplayMemberPath="Label"
                                                          SelectedValuePath="Key"
                                                          SelectedValue="{Binding MeasurementRuleKey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>

                                    <DataGridTextColumn Header="Fonte" Binding="{Binding SourceRequirementLabel}" Width="150" IsReadOnly="True" />

                                    <DataGridTemplateColumn Header="Area" Width="240">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <ComboBox ItemsSource="{Binding DataContext.SurfaceOptions, RelativeSource={RelativeSource AncestorType=Window}}"
                                                          DisplayMemberPath="DisplayLabel"
                                                          SelectedValuePath="SelectionKey"
                                                          SelectedValue="{Binding AreaSurfaceKey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>

                                    <DataGridTemplateColumn Header="Top" Width="240">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <ComboBox ItemsSource="{Binding DataContext.SurfaceOptions, RelativeSource={RelativeSource AncestorType=Window}}"
                                                          DisplayMemberPath="DisplayLabel"
                                                          SelectedValuePath="SelectionKey"
                                                          SelectedValue="{Binding TopSurfaceKey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>

                                    <DataGridTemplateColumn Header="Bot" Width="240">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <ComboBox ItemsSource="{Binding DataContext.SurfaceOptions, RelativeSource={RelativeSource AncestorType=Window}}"
                                                          DisplayMemberPath="DisplayLabel"
                                                          SelectedValuePath="SelectionKey"
                                                          SelectedValue="{Binding BottomSurfaceKey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>

                                    <DataGridTemplateColumn Header="Vol" Width="240">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <ComboBox ItemsSource="{Binding DataContext.SurfaceOptions, RelativeSource={RelativeSource AncestorType=Window}}"
                                                          DisplayMemberPath="DisplayLabel"
                                                          SelectedValuePath="SelectionKey"
                                                          SelectedValue="{Binding VolumeSurfaceKey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>

                                    <DataGridTextColumn Header="Status" Binding="{Binding StatusText}" Width="220" IsReadOnly="True" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </Border>
                    </Grid>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="1"
                Grid.ColumnSpan="3"
                Margin="0,20,0,0"
                Style="{StaticResource CardStyle}"
                Padding="18">
            <DockPanel LastChildFill="False">
                <Border DockPanel.Dock="Left"
                        Visibility="{Binding HasStatusMessage, Converter={StaticResource BoolToVisibilityConverter}}"
                        Padding="14,10"
                        CornerRadius="14"
                        Background="{Binding StatusBackground}">
                    <TextBlock Text="{Binding StatusMessage}"
                               Foreground="{Binding StatusForeground}"
                               FontSize="13"
                               TextWrapping="Wrap" />
                </Border>

                <StackPanel DockPanel.Dock="Right"
                            Orientation="Horizontal">
                    <Button Width="118"
                            Margin="0,0,10,0"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Content="Cancelar"
                            Click="Cancel_Click" />
                    <Button Width="170"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Content="Gerar quantitativo"
                            IsEnabled="{Binding CanExport}"
                            Click="Export_Click" />
                </StackPanel>
            </DockPanel>
        </Border>
    </Grid>
</Window>
