<Window x:Class="AutomacoesCivil3D.LoinFluxoCompletoWindow"
        x:ClassModifier="internal"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Fluxo Completo LOIN — Corredor → IFC"
        Width="960" Height="720"
        MinWidth="820" MinHeight="600"
        WindowStartupLocation="CenterScreen"
        Background="#F2F5F8"
        FontFamily="Bahnschrift">

    <Window.Resources>
        <SolidColorBrush x:Key="HeroBrush"       Color="#10324B"/>
        <SolidColorBrush x:Key="AccentBrush"     Color="#147A8A"/>
        <SolidColorBrush x:Key="SurfaceBrush"    Color="#FCFDFE"/>
        <SolidColorBrush x:Key="SoftBorderBrush" Color="#D4DEE7"/>
        <SolidColorBrush x:Key="TextBrush"       Color="#173042"/>
        <SolidColorBrush x:Key="MutedBrush"      Color="#5F7384"/>
        <SolidColorBrush x:Key="OkBrush"         Color="#2E7D32"/>
        <SolidColorBrush x:Key="WarnBrush"       Color="#E65100"/>
        <SolidColorBrush x:Key="ErrBrush"        Color="#C62828"/>
        <SolidColorBrush x:Key="PendingBrush"    Color="#9AA9B6"/>

        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background"      Value="{StaticResource SurfaceBrush}"/>
            <Setter Property="CornerRadius"    Value="14"/>
            <Setter Property="Padding"         Value="14"/>
            <Setter Property="BorderBrush"     Value="{StaticResource SoftBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style x:Key="PrimaryBtn" TargetType="Button">
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="Background"      Value="{StaticResource AccentBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="20,9"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Cursor"          Value="Hand"/>
        </Style>

        <Style x:Key="SecondaryBtn" TargetType="Button" BasedOn="{StaticResource PrimaryBtn}">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="Background" Value="#E6EDF2"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="70"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="64"/>
        </Grid.RowDefinitions>

        <!-- ========= HEADER ========= -->
        <Border Grid.Row="0" Background="{StaticResource HeroBrush}" Padding="22,0">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Border Width="38" Height="38" CornerRadius="9" Background="#1A8F9F" Margin="0,0,14,0">
                    <TextBlock Text="▶" Foreground="White" FontWeight="Bold" FontSize="18"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Fluxo Completo LOIN" Foreground="White" FontSize="18" FontWeight="SemiBold"/>
                    <TextBlock Text="7 etapas: Dados do Projeto → Mapeamento → Code Set → IFC Mapping → Exportar Sólidos → APLICARPSETTODOS → IFCEXPORT"
                               Foreground="#9BBFD6" FontSize="11"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- ========= BODY ========= -->
        <Grid Grid.Row="1" Margin="14,12,14,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="3*"/>
            </Grid.ColumnDefinitions>

            <!-- ===== Coluna esquerda: lista de etapas com checkboxes ===== -->
            <Border Grid.Column="0" Style="{StaticResource CardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="0,0,0,12">
                        <TextBlock Text="Etapas do fluxo" FontSize="15" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextBrush}"/>
                        <TextBlock Margin="0,4,0,0" FontSize="12"
                                   Foreground="{StaticResource MutedBrush}"
                                   TextWrapping="Wrap"
                                   Text="Cada etapa pode ser pulada (desmarcar). O botão Executar roda as marcadas em ordem."/>
                    </StackPanel>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <!-- Etapa 1 -->
                            <Border Background="#F8FAFC" CornerRadius="10" Padding="12,10" Margin="0,0,0,10"
                                    BorderBrush="{StaticResource SoftBorderBrush}" BorderThickness="1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <CheckBox Grid.Column="0" IsChecked="{Binding Run1}" Margin="0,4,10,0"/>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="1. Dados do Projeto (Pset_A)"
                                                   FontWeight="SemiBold" FontSize="13"
                                                   Foreground="{StaticResource TextBrush}"/>
                                        <TextBlock Text="{Binding Status1}" FontSize="11"
                                                   Foreground="{Binding Status1Brush}"
                                                   TextWrapping="Wrap" Margin="0,3,0,0"/>
                                    </StackPanel>
                                    <Button Grid.Column="2" Content="Abrir agora" Style="{StaticResource SecondaryBtn}"
                                            FontSize="11" Padding="10,6" VerticalAlignment="Top"
                                            Click="AbrirProjeto_Click"/>
                                </Grid>
                            </Border>

                            <!-- Etapa 2 -->
                            <Border Background="#F8FAFC" CornerRadius="10" Padding="12,10" Margin="0,0,0,10"
                                    BorderBrush="{StaticResource SoftBorderBrush}" BorderThickness="1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <CheckBox Grid.Column="0" IsChecked="{Binding Run2}" Margin="0,4,10,0"/>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="2. Mapeamento LOIN (camadas/codes → linhas LOIN)"
                                                   FontWeight="SemiBold" FontSize="13"
                                                   Foreground="{StaticResource TextBrush}"/>
                                        <TextBlock Text="{Binding Status2}" FontSize="11"
                                                   Foreground="{Binding Status2Brush}"
                                                   TextWrapping="Wrap" Margin="0,3,0,0"/>
                                    </StackPanel>
                                    <Button Grid.Column="2" Content="Abrir agora" Style="{StaticResource SecondaryBtn}"
                                            FontSize="11" Padding="10,6" VerticalAlignment="Top"
                                            Click="AbrirMapeamento_Click"/>
                                </Grid>
                            </Border>

                            <!-- Etapa 3 -->
                            <Border Background="#F8FAFC" CornerRadius="10" Padding="12,10" Margin="0,0,0,10"
                                    BorderBrush="{StaticResource SoftBorderBrush}" BorderThickness="1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <CheckBox Grid.Column="0" IsChecked="{Binding Run3}" Margin="0,4,10,0"/>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="3. Code Set Styles dos corredores (Shape/Link/Marker)"
                                                   FontWeight="SemiBold" FontSize="13"
                                                   Foreground="{StaticResource TextBrush}"/>
                                        <TextBlock Text="{Binding Status3}" FontSize="11"
                                                   Foreground="{Binding Status3Brush}"
                                                   TextWrapping="Wrap" Margin="0,3,0,0"/>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <!-- Etapa 4 -->
                            <Border Background="#F8FAFC" CornerRadius="10" Padding="12,10" Margin="0,0,0,10"
                                    BorderBrush="{StaticResource SoftBorderBrush}" BorderThickness="1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <CheckBox Grid.Column="0" IsChecked="{Binding Run4}" Margin="0,4,10,0"/>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="4. Linkar IfcInfraExportMapping.xlsx + JSON"
                                                   FontWeight="SemiBold" FontSize="13"
                                                   Foreground="{StaticResource TextBrush}"/>
                                        <TextBlock Text="{Binding Status4}" FontSize="11"
                                                   Foreground="{Binding Status4Brush}"
                                                   TextWrapping="Wrap" Margin="0,3,0,0"/>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <!-- Etapa 5 -->
                            <Border Background="#F8FAFC" CornerRadius="10" Padding="12,10" Margin="0,0,0,10"
                                    BorderBrush="{StaticResource SoftBorderBrush}" BorderThickness="1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <CheckBox Grid.Column="0" IsChecked="{Binding Run5}" Margin="0,4,10,0"/>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="5. Exportar sólidos com PSets LOIN"
                                                   FontWeight="SemiBold" FontSize="13"
                                                   Foreground="{StaticResource TextBrush}"/>
                                        <TextBlock Text="{Binding Status5}" FontSize="11"
                                                   Foreground="{Binding Status5Brush}"
                                                   TextWrapping="Wrap" Margin="0,3,0,0"/>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <!-- Etapa 6 — APLICARPSETTODOS -->
                            <Border Background="#F8FAFC" CornerRadius="10" Padding="12,10" Margin="0,0,0,10"
                                    BorderBrush="{StaticResource SoftBorderBrush}" BorderThickness="1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <CheckBox Grid.Column="0" IsChecked="{Binding Run6}" Margin="0,4,10,0"/>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="6. APLICARPSETTODOS — preenche Largura/Altura/Volume no Pset_C unificado"
                                                   FontWeight="SemiBold" FontSize="13"
                                                   Foreground="{StaticResource TextBrush}"/>
                                        <TextBlock Text="{Binding Status6}" FontSize="11"
                                                   Foreground="{Binding Status6Brush}"
                                                   TextWrapping="Wrap" Margin="0,3,0,0"/>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <!-- Etapa 7 — IFCEXPORT (era 6) -->
                            <Border Background="#FFF9F1" CornerRadius="10" Padding="12,10" Margin="0,0,0,10"
                                    BorderBrush="#F0E2C8" BorderThickness="1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <CheckBox Grid.Column="0" IsChecked="{Binding Run7}" Margin="0,4,10,0"/>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="7. Disparar IFCEXPORT nativo no DWG destino (opcional)"
                                                   FontWeight="SemiBold" FontSize="13"
                                                   Foreground="{StaticResource TextBrush}"/>
                                        <TextBlock Text="{Binding Status7}" FontSize="11"
                                                   Foreground="{Binding Status7Brush}"
                                                   TextWrapping="Wrap" Margin="0,3,0,0"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>

            <!-- ===== Coluna direita: log streaming ===== -->
            <Border Grid.Column="2" Style="{StaticResource CardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="0,0,0,10">
                        <TextBlock Text="Log do fluxo" FontSize="15" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextBrush}"/>
                        <TextBlock Margin="0,4,0,0" FontSize="11"
                                   Foreground="{StaticResource MutedBrush}"
                                   TextWrapping="Wrap"
                                   Text="{Binding CaminhoLog}"/>
                    </StackPanel>

                    <Border Grid.Row="1" Background="#0E1F2C" CornerRadius="8"
                            BorderBrush="#1E3245" BorderThickness="1">
                        <ScrollViewer x:Name="LogScroll" VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Auto" Padding="10,8">
                            <TextBlock x:Name="LogText"
                                       Text="{Binding LogTexto, FallbackValue='Aguardando execução...'}"
                                       Foreground="#D7E8F2"
                                       FontFamily="Consolas, Courier New"
                                       FontSize="11"
                                       TextWrapping="Wrap"/>
                        </ScrollViewer>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <!-- ========= FOOTER ========= -->
        <Border Grid.Row="2" Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource SoftBorderBrush}" BorderThickness="0,1,0,0">
            <Grid Margin="16,0">
                <TextBlock Text="{Binding StatusGeral}"
                           Foreground="{StaticResource MutedBrush}" FontSize="12"
                           HorizontalAlignment="Left" VerticalAlignment="Center"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button Content="Atualizar pré-checks" Style="{StaticResource SecondaryBtn}"
                            Margin="0,0,8,0" Click="Atualizar_Click"/>
                    <Button Content="Fechar" Style="{StaticResource SecondaryBtn}"
                            Margin="0,0,8,0" Click="Cancelar_Click"/>
                    <Button Content="▶  Executar etapas marcadas" Style="{StaticResource PrimaryBtn}"
                            Click="Executar_Click"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
