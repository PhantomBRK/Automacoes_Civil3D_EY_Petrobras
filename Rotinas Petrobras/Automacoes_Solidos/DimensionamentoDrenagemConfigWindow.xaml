<Window x:Class="AutomacoesCivil3D.DimensionamentoDrenagemConfigWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Dimensionamento de Drenagem — SOLIDOS Petrobras"
        Width="1000" Height="720"
        MinWidth="900" MinHeight="600"
        WindowStartupLocation="CenterScreen"
        Background="#F3F6FA"
        FontFamily="Bahnschrift">
    <Window.Resources>
        <SolidColorBrush x:Key="HeroBrush" Color="#10324B" />
        <SolidColorBrush x:Key="AccentBrush" Color="#157A87" />
        <SolidColorBrush x:Key="SurfaceBrush" Color="#FCFDFE" />
        <SolidColorBrush x:Key="BorderBrushSoft" Color="#D6DFE8" />
        <SolidColorBrush x:Key="TextBrush" Color="#173042" />
        <SolidColorBrush x:Key="MutedBrush" Color="#607080" />

        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
            <Setter Property="CornerRadius" Value="18" />
            <Setter Property="Padding" Value="18" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
        </Style>

        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource MutedBrush}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Margin" Value="0,0,0,3" />
        </Style>

        <Style x:Key="InputStyle" TargetType="TextBox">
            <Setter Property="Height" Value="38" />
            <Setter Property="Padding" Value="10,7" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style x:Key="ComboStyle" TargetType="ComboBox">
            <Setter Property="Height" Value="38" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="{StaticResource AccentBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="18,12" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="Background" Value="#E7EDF3" />
        </Style>

        <Style x:Key="ChkStyle" TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Margin" Value="0,2,16,2" />
        </Style>
    </Window.Resources>

    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300" />
            <ColumnDefinition Width="18" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- HERO lateral -->
        <Border Grid.Row="0" Grid.RowSpan="2" Grid.Column="0"
                Background="{StaticResource HeroBrush}"
                CornerRadius="24" Padding="24">
            <StackPanel>
                <Border Width="64" Height="64" CornerRadius="18"
                        Background="#1A90A0" HorizontalAlignment="Left">
                    <Viewbox Margin="14">
                        <TextBlock Text="∅" Foreground="White" FontWeight="Bold" />
                    </Viewbox>
                </Border>

                <TextBlock Margin="0,20,0,8" FontSize="24" FontWeight="SemiBold"
                           Foreground="White" Text="Drenagem por gravidade" />
                <TextBlock TextWrapping="Wrap" Foreground="#C9DAE7" FontSize="13" LineHeight="21"
                           Text="Replica a lógica de dimensionamento do SOLIDOS (Manning) e escolhe DN e declividade por MENOR ESCAVAÇÃO, validando dois regimes." />

                <Border Margin="0,22,0,0" CornerRadius="16" Background="#0F415E" Padding="16">
                    <StackPanel>
                        <TextBlock Text="Dois regimes" FontSize="14" FontWeight="SemiBold" Foreground="White" />
                        <TextBlock Margin="0,8,0,0" TextWrapping="Wrap" Foreground="#D0E2EE"
                                   FontSize="12" LineHeight="19"
                                   Text="Pluvial (Qini = HCalcIni.Qesc) e Incêndio (Qfim = HCalcFim.Qesc). O mesmo i tem que passar nos dois; sem Qfim, dimensiona só pelo pluvial." />
                    </StackPanel>
                </Border>

                <Border Margin="0,16,0,0" CornerRadius="16" Background="#FFF6EF"
                        BorderBrush="#F2D8C8" BorderThickness="1" Padding="14">
                    <TextBlock TextWrapping="Wrap" Foreground="#7B583F" FontSize="12" LineHeight="18"
                               Text="As regras são salvas em %APPDATA%\AutomacoesPetrobras e reaproveitadas na próxima execução." />
                </Border>
            </StackPanel>
        </Border>

        <!-- CONTEÚDO -->
        <ScrollViewer Grid.Row="0" Grid.Column="2" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- Regime PLUVIAL -->
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionTitle}" Text="Regime pluvial (principal · Qini)" />
                        <Grid Margin="0,14,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="14" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="14" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Style="{StaticResource FieldLabel}" Text="V mín (m/s)" />
                                <TextBox x:Name="TxtVmin" Style="{StaticResource InputStyle}" />
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Style="{StaticResource FieldLabel}" Text="V máx (m/s)" />
                                <TextBox x:Name="TxtVmax" Style="{StaticResource InputStyle}" />
                            </StackPanel>
                            <StackPanel Grid.Column="4">
                                <TextBlock Style="{StaticResource FieldLabel}" Text="Lâmina máx Y/D (%)" />
                                <TextBox x:Name="TxtYDmax" Style="{StaticResource InputStyle}" />
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Regime INCÊNDIO -->
                <Border Margin="0,16,0,0" Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <DockPanel LastChildFill="False">
                            <TextBlock DockPanel.Dock="Left" Style="{StaticResource SectionTitle}"
                                       Text="Regime incêndio (verificação · Qfim)" />
                            <CheckBox DockPanel.Dock="Right" x:Name="ChkIncendio"
                                      Style="{StaticResource ChkStyle}" Content="Ativo" />
                        </DockPanel>
                        <TextBlock Margin="0,4,0,12" Foreground="{StaticResource MutedBrush}" FontSize="12"
                                   TextWrapping="Wrap"
                                   Text="Vazão pontual de regime crítico (HCalcFim.Qesc). Sem Vmín — só limita lâmina e velocidade máxima. Tubos sem Qfim usam apenas o pluvial." />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="14" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Style="{StaticResource FieldLabel}" Text="V máx (m/s)" />
                                <TextBox x:Name="TxtIncVmax" Style="{StaticResource InputStyle}" />
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Style="{StaticResource FieldLabel}" Text="Lâmina máx Y/D (%)" />
                                <TextBox x:Name="TxtIncYDmax" Style="{StaticResource InputStyle}" />
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Declividade + material -->
                <Border Margin="0,16,0,0" Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionTitle}" Text="Declividade, material e cotas" />
                        <Grid Margin="0,14,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="14" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="14" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Style="{StaticResource FieldLabel}" Text="i mín (%)" />
                                <TextBox x:Name="TxtSlopeMin" Style="{StaticResource InputStyle}" />
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Style="{StaticResource FieldLabel}" Text="i máx (%)" />
                                <TextBox x:Name="TxtSlopeMax" Style="{StaticResource InputStyle}" />
                            </StackPanel>
                            <StackPanel Grid.Column="4">
                                <TextBlock Style="{StaticResource FieldLabel}" Text="Passo i (%)" />
                                <TextBox x:Name="TxtSlopeStep" Style="{StaticResource InputStyle}" />
                            </StackPanel>
                        </Grid>
                        <Grid Margin="0,12,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="14" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="14" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Style="{StaticResource FieldLabel}" Text="Manning (n)" />
                                <TextBox x:Name="TxtManning" Style="{StaticResource InputStyle}" />
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Style="{StaticResource FieldLabel}" Text="Recobrim. mín (m)" />
                                <TextBox x:Name="TxtRecobrimento" Style="{StaticResource InputStyle}" />
                            </StackPanel>
                            <StackPanel Grid.Column="4" VerticalAlignment="Bottom">
                                <CheckBox x:Name="ChkPontoBaixo" Style="{StaticResource ChkStyle}"
                                          Content="Junções em PONTO BAIXO" Margin="0,0,0,8" />
                            </StackPanel>
                        </Grid>

                        <Border Margin="0,14,0,0" CornerRadius="12" Background="#FFF6EF"
                                BorderBrush="#F2D8C8" BorderThickness="1" Padding="14">
                            <StackPanel>
                                <CheckBox x:Name="ChkManterCotas" Style="{StaticResource ChkStyle}"
                                          FontWeight="SemiBold"
                                          Content="Manter cotas e declividade — alterar SÓ o diâmetro" />
                                <TextBlock Margin="24,5,0,0" Foreground="{StaticResource MutedBrush}"
                                           FontSize="11" TextWrapping="Wrap" LineHeight="17"
                                           Text="Não recalcula cotas nem declividade: mantém a geometria atual do tubo e escolhe o MENOR DN que atende lâmina e velocidade na declividade existente. Para troncos de cota fixa (exutório controlado). Ignora i mín/máx e PONTO BAIXO; se nem o maior DN atender a autolimpeza (Vmín), avisa." />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- Faixa dinâmica de diâmetros -->
                <Border Margin="0,16,0,0" Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionTitle}" Text="Faixa de diâmetros (DN em mm)" />
                        <TextBlock Margin="0,4,0,12" Foreground="{StaticResource MutedBrush}" FontSize="12"
                                   TextWrapping="Wrap"
                                   Text="Marque os DNs disponíveis para esta execução. Use 'De / Até' para selecionar rapidamente uma faixa contígua, ou marque/desmarque individualmente para uma faixa não-contígua." />
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="10" />
                                <ColumnDefinition Width="160" />
                                <ColumnDefinition Width="10" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="10" />
                                <ColumnDefinition Width="160" />
                                <ColumnDefinition Width="14" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="10" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" VerticalAlignment="Center"
                                       Style="{StaticResource FieldLabel}" Text="De:" Margin="0,0,0,0" />
                            <ComboBox Grid.Column="2" x:Name="CboDe" Style="{StaticResource ComboStyle}" />
                            <TextBlock Grid.Column="4" VerticalAlignment="Center"
                                       Style="{StaticResource FieldLabel}" Text="Até:" Margin="0,0,0,0" />
                            <ComboBox Grid.Column="6" x:Name="CboAte" Style="{StaticResource ComboStyle}" />
                            <Button Grid.Column="8" Style="{StaticResource SecondaryButtonStyle}"
                                    Content="Aplicar faixa" Padding="14,8" Click="OnAplicarFaixa" />
                            <Button Grid.Column="10" Style="{StaticResource SecondaryButtonStyle}"
                                    Content="Todos" Padding="14,8" Click="OnMarcarTodos" />
                        </Grid>
                        <Border CornerRadius="12" Background="White"
                                BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" Padding="12">
                            <WrapPanel x:Name="PanelDNs" />
                        </Border>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Rodapé de ações -->
        <Border Grid.Row="1" Grid.Column="2" Margin="0,16,0,0"
                Style="{StaticResource CardStyle}" Padding="14">
            <DockPanel LastChildFill="False">
                <Button DockPanel.Dock="Left"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Content="Restaurar padrão" Click="OnRestaurarDefault" />
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button Width="120" Margin="0,0,10,0"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Content="Cancelar" Click="OnCancelar" />
                    <Button Width="170"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Content="Dimensionar" IsDefault="True" Click="OnDimensionar" />
                </StackPanel>
            </DockPanel>
        </Border>
    </Grid>
</Window>
